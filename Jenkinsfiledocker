pipeline {
    agent any
    tools {
      maven 'Maven-3.9.15'
    }
    triggers{
        githubPush()
    }
    stages {
        stage('mvn build') {
            steps {
                // Get some code from a GitHub repository 
               sh" mvn clean package "
               echo "mvn build successful"
            }
        }
        stage('Code Quality') {
            steps {
          withCredentials([string(credentialsId: 'Sonar_token', variable: 'SONAR_TOKEN')]) {
            sh """
            mvn test sonar:sonar -Dsonar.token=${SONAR_TOKEN}
            """
            echo "Code quality analysis completed"
          }
            }
        }
        stage('Generate Report') {
            steps {
                // Example: Export issues to CSV using SonarQube API
                withCredentials([string(credentialsId: 'Sonar_token', variable: 'SONAR_TOKEN')]) {
                sh """
                # Export issues to CSV
                curl -s -u ${SONAR_TOKEN}: http://3.82.175.120:9000/api/issues/search?componentKeys=com.rushi:student-reg-webapp&types=BUG,VULNERABILITY,CODE_SMELL \
                | jq -r '.issues[] | [.key, .type, .severity, .message] | @csv' > sonar_report.csv
                ls -l sonar_report.csv
                head -n 5 sonar_report.csv || echo 'CSV is empty'
                # Export summary metrics (bugs, vulnerabilities, code_smells, coverage)
                curl -s -u ${SONAR_TOKEN}: "http://3.82.175.120:9000/api/measures/component?component=com.rushi:student-reg-webapp&metricKeys=bugs,vulnerabilities,code_smells,coverage,duplicated_lines_density" \
                | jq -r '.component.measures[] | [.metric, .value] | @csv' > sonar_summary.csv

                ls -l sonar_report.csv sonar_summary.csv
                head -n 5 sonar_summary.csv || echo 'CSV is empty'
                """
                archiveArtifacts artifacts: 'sonar_report.csv', fingerprint: true
                echo "SonarQube report generated and archived"
                }
            }
        }
        stage('Email Report') {
            steps {
                emailext(
                    subject: "SonarQube Report - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body: """Hello Team,

Attached is the SonarQube analysis report for build #${env.BUILD_NUMBER}.
Key metrics:
- Bugs, Vulnerabilities, Code Smells exported
- Quality Gate status: ${currentBuild.result}

Regards,
CI/CD Pipeline
""",
                    to: 'devopsmanu1909@gmail.com',
                    attachmentsPattern: '*.csv'
                        )
                
            }
            
        }
    }
}
    
