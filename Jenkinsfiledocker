pipeline {
    agent any
    tools {
      maven 'Maven-3.9.15'
    }
    triggers{
        githubPush()
    }
    stages {
        stage('mvn build') {
            steps {
                // Get some code from a GitHub repository 
               sh" mvn clean package "
            }
        }
        stage('Code Quality') {
            steps {
          withCredentials([string(credentialsId: 'Sonar', variable: 'Sonar')]) {
            sh """
            mvn clean test sonar:sonar -Dsonar.token=${Sonar}]
            """
            }
            }
        }
    }
}
    
