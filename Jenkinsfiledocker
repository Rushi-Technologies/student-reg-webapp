pipeline {
    agent any
    tools {
      maven 'Maven-3.9.15'
    }
    triggers{
        githubPush()
    }
    stages {
        stage('mvn build') {
            steps {
                // Get some code from a GitHub repository 
               sh" mvn clean package "
            }
        }
        stage('Code Quality') {
            steps {
          withCredentials([string(credentialsId: 'Sonar_token', variable: 'Sonar')]) {
            sh """
            mvn clean test -X sonar:sonar -Dsonar.token=""${Sonar}""
            """
          }
            }
        }
        stage('Generate Report') {
            steps {
                // Example: Export issues to CSV using SonarQube API
                sh '''
                curl -s -u $SONAR_TOKEN: http://3.82.175.120:9000/api/issues/search?componentKeys=student-reg-webapp&types=BUG,VULNERABILITY,CODE_SMELL \
                | jq -r '.issues[] | [.key, .type, .severity, .message] | @csv' > sonar_report.csv
                '''
                archiveArtifacts artifacts: 'sonar_report.csv', fingerprint: true
            }
        stage('Email Report') {
            steps {
                emailext(
                    subject: "SonarQube Report - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                    body: """Hello Team,

        Attached is the SonarQube analysis report for build #${env.BUILD_NUMBER}.

        Key metrics:
        - Bugs, Vulnerabilities, Code Smells exported
        - Quality Gate status: ${currentBuild.result}

        Regards,
        CI/CD Pipeline
        """,
                            to: 'devopsmanu1909@gmail.com',
                            attachmentsPattern: 'sonar_report.csv'
                        )
                    }
                }
        }
    }
}
    
